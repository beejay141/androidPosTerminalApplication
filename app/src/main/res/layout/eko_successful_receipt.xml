<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android" >
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:src="@drawable/eko_electric_logo"
        android:layout_marginBottom="@dimen/medium_padding"
        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height= "wrap_content"
        style="@style/default_receipt_style"
        android:text = "Eko Electricity Distribution Receipt"
        android:gravity="center"
        android:textStyle="bold"
        />

    <TextView
        android:id="@+id/currentTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/ekoTransactionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/default_receipt_style"
        android:text="APPROVED"
        android:layout_gravity="center"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text = "Terminal ID"
            style="@style/default_receipt_style" />

        <TextView
            android:id="@+id/ekoTerminalId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            style="@style/default_receipt_style"
            android:text = "42952400"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text = "Transaction ID"
            style="@style/default_receipt_style"/>

        <TextView
            android:id="@+id/ekoTransactionId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text = "42952400"
            style="@style/default_receipt_style"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text = "Customer Name"
            style="@style/default_receipt_style"/>

        <TextView
            android:id="@+id/ekoCustomerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            style="@style/default_receipt_style"
            android:text = "Agbede, Samuel Damilola"/>

    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="16dp"
            android:text = "Customer Address"
            style="@style/default_receipt_style"/>

        <TextView
            android:id="@+id/ekoCustomerAddress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text = "64/65 Ahmadu Bello Way"
            style="@style/default_receipt_style"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/default_receipt_style"
            android:text = "Customer Number"/>

        <TextView
            android:id="@+id/ekoCustomerNumber"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/default_receipt_style"
            android:layout_weight="1"
            android:gravity="end"
            android:text = "4295240000"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/default_receipt_style"
            android:text = "Customer Account Type"/>

        <TextView
            android:id="@+id/ekoCustomerAccountType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/default_receipt_style"
            android:gravity="end"
            android:text = "4295240000"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/default_receipt_style"
            android:text = "Customer ID"/>

        <TextView
            android:id="@+id/ekoCustomerId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            style="@style/default_receipt_style"
            android:text = "4295240000"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/default_receipt_style"
            android:text = "Customer Business Unit"/>

        <TextView
            android:id="@+id/ekoCustomerBusiness"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            style="@style/default_receipt_style"
            android:text = "4295240000"/>

    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:id="@+id/tokenHolder"
        android:visibility="gone"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/default_receipt_style"
            android:id="@+id/token"
            android:layout_centerHorizontal="true"
            android:text = "12334958548739473974894738"/>


    </RelativeLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="center"
        style="@style/default_receipt_style"
        android:text="**********"/>

    <TextView
        android:id="@+id/ekoAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        style="@style/default_receipt_style"
        android:layout_marginBottom="@dimen/medium_padding"
        android:text="₦"/>


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:layout_gravity="center"
        style="@style/default_receipt_style"
        android:text="**********"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text = "Powered by Itex Integrated Services"
        android:layout_marginTop="32sp"/>
</LinearLayout>
</ScrollView>